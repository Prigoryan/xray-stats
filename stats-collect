#!/usr/bin/env bash

set -eo pipefail

here=$(dirname -- "$0")
source "$here/stats-utils.sh"

PATH=$PATH:/usr/local/bin:/usr/bin:/bin
stats=$(xray api statsquery -server "$API_SERVER" -reset)
today=$(date +%F)
user_down_up=$(jq -r -f "$here/stats-to-user-down-up.jq" <<< "$stats")

mkdir -p "$TRAFFIC_DIR"
while IFS= read -r line; do
    if [[ -z "$line" ]]; then
        continue
    fi

    IFS=$'\t' read -r user down up <<< "$line"

    # Reject names that would escape TRAFFIC_DIR.
    if [[ -z "$user" || "$user" == *"/"* || "$user" == "." || "$user" == ".." ]]; then
        echo "[stats-collect] skipping suspicious user name: $user" >&2
        continue
    fi

    if [[ "$down" == 0 && "$up" == 0 ]]; then
        continue
    fi

    echo "[stats-collect] user: $user, down: $down, up: $up"

    mkdir -p "$TRAFFIC_DIR/$user/down" "$TRAFFIC_DIR/$user/up"
    echo "$down" >> "$TRAFFIC_DIR/$user/down/$today"
    echo "$up" >> "$TRAFFIC_DIR/$user/up/$today"
done <<< "$user_down_up"
