#!/usr/bin/env bash

set -eo pipefail
shopt -s nullglob

source "$(dirname "$0")/stats-utils.sh"

isPlainOutput=false
if [ "$1" == "--plain" ]; then
    isPlainOutput=true
    shift
fi

print-header() {
    queryUser=$1
    queryDate=$2

    if [ "$isPlainOutput" = true ]; then
        return
    fi

    echo -e "\033[1;33m$queryUser:  \033[1;0m$queryDate\033[1;0m"
    echo
    echo -e "           \033[1;34m↓ down (mb) \033[1;32m↑ up (mb)\033[1;0m"
}

print-user-stats() {
    local username=$1
    local down=${2:-0}
    local up=${3:-0}

    if [ "$down" -eq 0 ] && [ "$up" -eq 0 ]; then
        return
    fi

    if [ "$isPlainOutput" = true ]; then
        echo "$username $down $up"
        return
    fi

    local downMb=$((down / 1024 / 1024))
    local upMb=$((up / 1024 / 1024))
    printf "%-10s \033[1;34m%10s \033[1;32m%10s\033[1;0m\n" "$username" "$downMb" "$upMb"
}

query() {
    local queryUser=${1:-*}
    local queryDate=$2
    local suffix=$3  # "" for a single day, "-*" for a whole month

    print-header "$queryUser" "$queryDate"

    for userDir in "$TRAFFIC_DIR"/$queryUser; do
        # shellcheck disable=SC2206 # $suffix is "" or "-*" — intentional glob.
        local downFiles=("$userDir/down/$queryDate"$suffix)
        # shellcheck disable=SC2206
        local upFiles=("$userDir/up/$queryDate"$suffix)
        local down up
        down=$(sum-num-file "${downFiles[@]}")
        up=$(sum-num-file "${upFiles[@]}")

        print-user-stats "$(basename "$userDir")" "$down" "$up"
    done
}


queryDate=${1:-$(date +%F)}
queryUser="${2:-*}"

if [[ "$queryDate" =~ ^[0-9]{4}-(0[1-9]|1[0-2])$ ]]; then
    query "$queryUser" "$queryDate" "-*"
    exit 0
fi

if [[ "$queryDate" =~ ^[0-9]{4}-(0[1-9]|1[0-2])-(0[1-9]|[12][0-9]|3[01])$ ]]; then
    query "$queryUser" "$queryDate" ""
    exit 0
fi

echo "Usage: $0 [--plain] [<YYYY-MM-DD>|<YYYY-MM>] [<user-glob>]" >&2
exit 1
