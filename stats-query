#!/usr/bin/env bash

set -eo pipefail
shopt -s nullglob

source "$(dirname "$0")/stats-utils.sh"

isPlainOutput=false
if [ "$1" == "--plain" ]; then
    isPlainOutput=true
    shift
fi

# ANSI color constants used by print-header and print-user-stats.
# Column colors (regular weight): down=blue, up=magenta, total=white.
# Unit-letter heatmap (bright + bold): K=green, M=yellow, G/T=red.
R=$'\033[0m'
DOWN=$'\033[34m'   ; UP=$'\033[35m'   ; TOTAL=$'\033[37m'
HEAT_K=$'\033[1;32m' ; HEAT_M=$'\033[1;33m' ; HEAT_G=$'\033[1;31m'

# cell <bytes> <column-color-escape> <visible-width>
# Right-aligns a numfmt-formatted byte count within `width` visible chars,
# coloring digits with the column color and the unit letter with the
# heatmap color. Emits no ANSI in --plain mode (cell is not called there).
cell() {
    local bytes=$1 col=$2 width=$3
    local visible
    # LC_ALL=C forces numfmt to use '.' as the decimal separator and
    # ASCII digits, regardless of the user's locale, so the regex below
    # (which expects '.') always matches.
    visible=$(LC_ALL=C numfmt --to=iec "$bytes")
    local pad=$(( width - ${#visible} ))
    (( pad > 0 )) && printf '%*s' "$pad" ''
    if [[ $visible =~ ^([0-9.]+)([KMGT])$ ]]; then
        local digits=${BASH_REMATCH[1]} letter=${BASH_REMATCH[2]} hm
        case $letter in
            K)   hm=$HEAT_K ;;
            M)   hm=$HEAT_M ;;
            G|T) hm=$HEAT_G ;;
        esac
        printf '%s%s%s%s%s%s' "$col" "$digits" "$R" "$hm" "$letter" "$R"
    else
        printf '%s%s%s' "$col" "$visible" "$R"
    fi
}

print-header() {
    queryUser=$1
    queryDate=$2

    if [ "$isPlainOutput" = true ]; then
        return
    fi

    echo -e "\033[1;33m$queryUser:\033[0m  $queryDate"
    echo
    # Column header row: empty name area, then three columns right-aligned
    # within a 7-visible-char box, separated by 2-space gaps. Leading spaces
    # are hand-tuned because printf width specifiers count UTF-8 byte length,
    # not visible char width.
    printf '  %-8s' ''
    printf ' %s↓ down%s'  "$DOWN"  "$R"
    printf '  '
    printf '   %s↑ up%s'  "$UP"    "$R"
    printf '  '
    printf '%s∑ total%s'  "$TOTAL" "$R"
    printf '\n'
}

print-user-stats() {
    local username=$1
    local down=${2:-0}
    local up=${3:-0}
    local combined=$((down + up))

    if [ "$combined" -eq 0 ]; then
        return
    fi

    if [ "$isPlainOutput" = true ]; then
        echo "$username $down $up $combined"
        return
    fi

    local nameColor='' nameReset=''
    if [ "$username" = total ]; then
        echo
        nameColor=$'\033[1;33m'
        nameReset=$R
    fi
    printf '  %s%-8s%s' "$nameColor" "$username" "$nameReset"
    cell "$down"     "$DOWN"  7
    printf '  '
    cell "$up"       "$UP"    7
    printf '  '
    cell "$combined" "$TOTAL" 7
    printf '\n'
}

query() {
    local queryUser=${1:-*}
    local queryDate=$2
    local suffix=$3  # "" for a single day, "-*" for a whole month

    print-header "$queryUser" "$queryDate"

    local totalDown=0 totalUp=0
    for userDir in "$TRAFFIC_DIR"/$queryUser; do
        # shellcheck disable=SC2206 # $suffix is "" or "-*" — intentional glob.
        local downFiles=("$userDir/down/$queryDate"$suffix)
        # shellcheck disable=SC2206
        local upFiles=("$userDir/up/$queryDate"$suffix)
        local down up
        down=$(sum-num-file "${downFiles[@]}")
        up=$(sum-num-file "${upFiles[@]}")

        print-user-stats "$(basename "$userDir")" "$down" "$up"
        totalDown=$((totalDown + down))
        totalUp=$((totalUp + up))
    done

    print-user-stats total "$totalDown" "$totalUp"
}


queryDate=${1:-$(date +%F)}
queryUser="${2:-*}"

if [[ "$queryDate" =~ ^[0-9]{4}-(0[1-9]|1[0-2])$ ]]; then
    query "$queryUser" "$queryDate" "-*"
    exit 0
fi

if [[ "$queryDate" =~ ^[0-9]{4}-(0[1-9]|1[0-2])-(0[1-9]|[12][0-9]|3[01])$ ]]; then
    query "$queryUser" "$queryDate" ""
    exit 0
fi

echo "Usage: $0 [--plain] [<YYYY-MM-DD>|<YYYY-MM>] [<user-glob>]" >&2
exit 1
